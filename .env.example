# -----------------------------------------------------------------------------
# VOIDGUARD - Environment Variables
# -----------------------------------------------------------------------------

# Backend Settings
PROJECT_NAME="VOIDGUARD"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Security & Encryption
# Generate a secure secret key: openssl rand -hex 32
SECRET_KEY="super-secret-key-change-this-in-production"
# AES-256 Key for agent payload encryption. Must be exactly 32 bytes (64 hex chars)
# Generate: openssl rand -hex 32
AES_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin"

# Database
# Format: postgresql+asyncpg://user:password@server:port/db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=voidguard_pwd
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=voidguard
DATABASE_URL="postgresql+asyncpg://postgres:voidguard_pwd@db:5432/voidguard"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6380
REDIS_PASSWORD=""

# ChromaDB (Vector Search)
CHROMA_HOST=chromadb
CHROMA_PORT=8000
